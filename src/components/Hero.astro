---
import AntigravityAgent from './AntigravityAgent';
---
<section id="inicio" class="relative min-h-screen flex items-center justify-start overflow-hidden pt-24 bg-bg-primary">
  <!-- Background Rejilla de Ingeniería -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:50px_50px] [mask-image:radial-gradient(circle_at_center,black_30%,transparent_80%)] pointer-events-none z-0"></div>
  
  <!-- Resplandor dinámico de fondo -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[40vw] h-[40vw] bg-accent-glow/10 rounded-full blur-[120px] pointer-events-none z-0"></div>

  <!-- Agente Antigravity en 3D (R3F) -->
  <!-- client:only="react" asegura que se renderice únicamente en el cliente, evitando fallos de SSR con Three.js -->
  <div class="absolute inset-0 w-full h-full z-10 pointer-events-none">
    <AntigravityAgent client:only="react" />
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full relative z-20 pointer-events-none">
    <div class="max-w-2xl text-left">
      <!-- Badge de disponibilidad -->
      <div class="reveal inline-flex items-center gap-3 px-4 py-2 bg-accent-dim/30 border border-accent/20 rounded-full font-mono text-sm text-accent mb-8 shadow-sm pointer-events-auto">
        <span class="w-2.5 h-2.5 bg-accent rounded-full animate-pulse shadow-[0_0_10px_#00d4aa]"></span>
        Disponible para nuevos proyectos
      </div>

      <!-- Título principal -->
      <h1 class="reveal text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-[1.1] mb-6 pointer-events-auto">
        Hola, soy <span class="bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">Carlos Méndez</span><br />
        Ingeniero de Software
      </h1>

      <!-- Descripción corta -->
      <p class="reveal text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl pointer-events-auto">
        Desarrollador apasionado por crear soluciones digitales innovadoras y escalables. Especializado en arquitectura de software, desarrollo full-stack y tecnologías cloud.
      </p>

      <!-- Botones de Acción -->
      <div class="reveal flex flex-wrap gap-4 mb-16 pointer-events-auto">
        <a href="#proyectos" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-accent to-accent-secondary hover:from-accent hover:to-accent text-bg-primary font-bold rounded-xl transition-all duration-300 transform hover:-translate-y-[2px] shadow-lg hover:shadow-accent-glow">
          Ver proyectos
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#contacto" class="inline-flex items-center gap-2 px-7 py-3.5 border border-border-custom hover:border-accent hover:text-accent font-semibold rounded-xl transition-all duration-300 transform hover:-translate-y-[2px]">
          Contactar
        </a>
      </div>

      <!-- Sección de Estadísticas -->
      <div class="hero-stats reveal border-t border-border-custom pt-8 flex flex-wrap gap-8 md:gap-12 pointer-events-auto">
        <div class="stat-item">
          <span class="stat-num font-mono text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent" data-target="5">0</span>
          <span class="font-mono text-xl font-bold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">+</span>
          <p class="text-xs text-text-secondary uppercase tracking-wider mt-1">Años de experiencia</p>
        </div>
        <div class="stat-item">
          <span class="stat-num font-mono text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent" data-target="50">0</span>
          <span class="font-mono text-xl font-bold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">+</span>
          <p class="text-xs text-text-secondary uppercase tracking-wider mt-1">Proyectos completados</p>
        </div>
        <div class="stat-item">
          <span class="stat-num font-mono text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent" data-target="30">0</span>
          <span class="font-mono text-xl font-bold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">+</span>
          <p class="text-xs text-text-secondary uppercase tracking-wider mt-1">Clientes satisfechos</p>
        </div>
        <div class="stat-item">
          <span class="stat-num font-mono text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent" data-target="3200">0</span>
          <span class="font-mono text-xl font-bold bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">+</span>
          <p class="text-xs text-text-secondary uppercase tracking-wider mt-1">Commits en GitHub</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animación del contador a 60fps
  function animateCounter(element: HTMLElement, target: number) {
    let current = 0;
    const duration = 2000; // 2 segundos
    const stepTime = Math.max(Math.floor(duration / target), 15);
    
    // Incremento dinámico para números grandes (como 3200)
    const increment = Math.ceil(target / (duration / 25));
    
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      element.textContent = current.toString();
    }, 25);
  }

  const statsSection = document.querySelector('.hero-stats');
  let animated = false;

  if (statsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !animated) {
          animated = true;
          const statNums = document.querySelectorAll('.stat-num');
          statNums.forEach(num => {
            const target = parseInt(num.getAttribute('data-target') || '0', 10);
            animateCounter(num as HTMLElement, target);
          });
        }
      });
    }, { threshold: 0.5 });
    
    observer.observe(statsSection);
  }
</script>
