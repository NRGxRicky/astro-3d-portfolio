---
---
<section id="formacion" class="py-24 md:py-32 bg-bg-primary relative">
  <!-- Brillos sutiles de fondo -->
  <div class="absolute right-0 top-1/4 w-[35vw] h-[35vw] bg-accent-glow/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-20">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Formación</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">Educación & Certificaciones</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Mi recorrido académico y mis acreditaciones oficiales en gestión y desarrollo.</p>
    </div>

    <!-- Timeline Container -->
    <div class="relative max-w-4xl mx-auto mb-24">
      <!-- Línea vertical central -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[2px] bg-border-custom -translate-x-1/2"></div>

      <!-- Timeline Items -->
      <div class="flex flex-col gap-12">
        
        <!-- Item 1: Ingeniería TIC (Lado izquierdo) -->
        <div class="relative flex flex-col md:flex-row md:justify-start items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-0 md:pr-8 md:text-right">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2013 - 2018</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">Ingeniería en Tecnologías de la Información y Comunicación</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Instituto Tecnológico de Puebla</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Formación en ingeniería de software, redes, bases de datos y telecomunicaciones, estableciendo una sólida base técnica en desarrollo backend y administración de sistemas.
              </p>
            </div>
          </div>
        </div>

        <!-- Item 2: Diplomado (Lado derecho) -->
        <div class="relative flex flex-col md:flex-row md:justify-end items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-8">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2020</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">Diplomado en Comunicación, Trabajo en Equipo y Liderazgo</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Universidad Santander</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Especialización en habilidades blandas aplicadas a equipos de alto rendimiento, comunicación asertiva, resolución de conflictos y liderazgo transformacional.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Certificaciones Grid -->
    <div class="reveal mt-16">
      <h3 class="text-2xl font-bold text-white text-center mb-10">Acreditaciones y Certificaciones</h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Cert 1: PMP -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">💼</div>
          <div>
            <h4 class="text-sm font-bold text-white">Project Management Professional (PMP)</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">PMI (Project Management Institute)</span>
          </div>
        </div>

        <!-- Cert 2: CSM -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">🛡️</div>
          <div>
            <h4 class="text-sm font-bold text-white">Certified Scrum Master (CSM)</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">Scrum Alliance</span>
          </div>
        </div>

        <!-- Cert 3: PMI-ACP -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">🔄</div>
          <div>
            <h4 class="text-sm font-bold text-white">Agile Certified Practitioner (PMI-ACP)</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">PMI (Project Management Institute)</span>
          </div>
        </div>

        <!-- Cert 4: ITIL -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">⚙️</div>
          <div>
            <h4 class="text-sm font-bold text-white">ITIL Foundation Certification</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">AXELOS</span>
          </div>
        </div>

        <!-- Cert 5: Google PM -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">📊</div>
          <div>
            <h4 class="text-sm font-bold text-white">Google Project Management</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">Google / Coursera</span>
          </div>
        </div>

        <!-- Cert 6: Scrum Foundation -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">🧩</div>
          <div>
            <h4 class="text-sm font-bold text-white">Scrum Foundation Professional</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">CertiProf</span>
          </div>
        </div>

        <!-- Cert 7: Lean Six Sigma -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">🎯</div>
          <div>
            <h4 class="text-sm font-bold text-white">White Belt Lean Six Sigma</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">International Lean Six Sigma</span>
          </div>
        </div>

        <!-- Cert 8: Cyber Security -->
        <div class="bg-bg-card border border-border-custom rounded-2xl p-6 flex flex-col gap-3 hover:border-accent/30 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 bg-accent-dim rounded-xl flex items-center justify-center text-lg text-accent">🔒</div>
          <div>
            <h4 class="text-sm font-bold text-white">Cyber Security Foundation</h4>
            <span class="block text-[10px] text-text-muted mt-1 uppercase tracking-wider">CertiProf</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
