---
---
<section id="formacion" class="py-24 md:py-32 bg-bg-primary relative">
  <!-- Brillos sutiles de fondo -->
  <div class="absolute right-0 top-1/4 w-[35vw] h-[35vw] bg-accent-glow/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-20">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Formación</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">Educación académica</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Mi recorrido académico y certificaciones profesionales.</p>
    </div>

    <!-- Timeline Container -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Línea vertical central -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[2px] bg-border-custom -translate-x-1/2"></div>

      <!-- Timeline Items -->
      <div class="flex flex-col gap-12">
        
        <!-- Item 1: Master (Lado izquierdo) -->
        <div class="relative flex flex-col md:flex-row md:justify-start items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-0 md:pr-8 md:text-right">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2021 - 2023</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">Máster en Ingeniería de Software</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Universidad Politécnica de Madrid</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Especialización en arquitecturas distribuidas y sistemas cloud. Tesis sobre optimización de microservicios con Kubernetes. Matrícula de honor.
              </p>
            </div>
          </div>
        </div>

        <!-- Item 2: Grado (Lado derecho) -->
        <div class="relative flex flex-col md:flex-row md:justify-end items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-8">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2017 - 2021</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">Grado en Ingeniería Informática</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Universidad Complutense de Madrid</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Formación integral en ciencias de la computación, algoritmos, bases de datos y desarrollo de software. Proyecto final: sistema de IA para predicción de tráfico.
              </p>
            </div>
          </div>
        </div>

        <!-- Item 3: AWS (Lado izquierdo) -->
        <div class="relative flex flex-col md:flex-row md:justify-start items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-0 md:pr-8 md:text-right">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2023</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">AWS Solutions Architect Professional</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Amazon Web Services</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Certificación profesional en diseño de arquitecturas seguras y resilientes en la nube de AWS, incluyendo patrones de alto rendimiento y optimización de costes.
              </p>
            </div>
          </div>
        </div>

        <!-- Item 4: GCP (Lado derecho) -->
        <div class="relative flex flex-col md:flex-row md:justify-end items-start md:items-center w-full reveal">
          <!-- Nodo brillante -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-bg-primary -translate-x-1/2 z-10 shadow-[0_0_15px_#00d4aa]"></div>
          
          <div class="w-full md:w-[calc(50%-2rem)] pl-12 md:pl-8">
            <div class="bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 group">
              <span class="font-mono text-xs font-bold text-accent tracking-wider block mb-2">2022</span>
              <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">Google Cloud Professional Developer</h3>
              <h4 class="text-sm font-medium text-text-secondary mt-1 mb-4">Google Cloud Platform</h4>
              <p class="text-sm text-text-secondary leading-relaxed">
                Certificación en desarrollo de aplicaciones escalables en GCP, servicios de machine learning y gestión de infraestructura como código.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
