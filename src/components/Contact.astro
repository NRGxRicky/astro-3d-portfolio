---
---
<section id="contacto" class="py-24 md:py-32 bg-bg-primary relative">
  <!-- Sutil resplandor de fondo -->
  <div class="absolute right-0 bottom-0 w-[40vw] h-[40vw] bg-accent-glow/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16 md:mb-20">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Contacto</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">¿Trabajamos juntos?</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Estoy siempre abierto a nuevas oportunidades y colaboraciones interesantes.</p>
    </div>

    <!-- Contenedor principal de contacto -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      
      <!-- Lado izquierdo: Información de contacto -->
      <div class="lg:col-span-5 reveal flex flex-col gap-8">
        <div>
          <h3 class="text-2xl font-bold text-white mb-4">
            Hablemos sobre tu <span class="bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">próximo proyecto</span>
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Si tienes una idea, un proyecto en mente o simplemente quieres saludar, no dudes en escribirme. Respondo en menos de 24 horas.
          </p>
        </div>

        <!-- Métodos de contacto -->
        <div class="flex flex-col gap-5">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-accent-dim border border-accent/10 rounded-xl flex items-center justify-center text-xl text-accent shrink-0 shadow-[0_0_10px_rgba(0,212,170,0.05)]">📧</div>
            <div>
              <span class="block text-[10px] text-text-muted uppercase tracking-wider">Email</span>
              <a href="mailto:delfinncruzricky@gmail.com" class="text-sm font-semibold text-white hover:text-accent transition-colors">delfinncruzricky@gmail.com</a>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-accent-dim border border-accent/10 rounded-xl flex items-center justify-center text-xl text-accent shrink-0 shadow-[0_0_10px_rgba(0,212,170,0.05)]">📍</div>
            <div>
              <span class="block text-[10px] text-text-muted uppercase tracking-wider">Ubicación</span>
              <p class="text-sm font-semibold text-white">Puebla, México (Remoto / Híbrido)</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-accent-dim border border-accent/10 rounded-xl flex items-center justify-center text-xl text-accent shrink-0 shadow-[0_0_10px_rgba(0,212,170,0.05)]">📱</div>
            <div>
              <span class="block text-[10px] text-text-muted uppercase tracking-wider">Teléfono</span>
              <a href="tel:+522214127004" class="text-sm font-semibold text-white hover:text-accent transition-colors">+52 22 1412 7004</a>
            </div>
          </div>
        </div>

        <!-- Redes sociales -->
        <div class="flex gap-4 mt-4">
          <a href="#" class="w-11 h-11 bg-bg-card border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent transition-all duration-300 transform hover:-translate-y-1 shadow" title="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="#" class="w-11 h-11 bg-bg-card border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent transition-all duration-300 transform hover:-translate-y-1 shadow" title="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="w-11 h-11 bg-bg-card border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent transition-all duration-300 transform hover:-translate-y-1 shadow" title="Twitter / X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="w-11 h-11 bg-bg-card border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent transition-all duration-300 transform hover:-translate-y-1 shadow" title="Dev.to">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v4.36h.58c.38 0 .66-.08.84-.23.2-.16.3-.44.3-.84v-2.22c0-.4-.1-.68-.3-.84zm13.07-6.21H3.51c-.96 0-1.74.78-1.74 1.74v13.82c0 .96.78 1.74 1.74 1.74h16.98c.96 0 1.74-.78 1.74-1.74V5.58c0-.96-.78-1.74-1.74-1.74zM9.52 14.5c0 .78-.35 1.2-1.13 1.34v.97H7.12v-.97H6.43v-1.24h.69v-2.87H6.43v-1.24h.69v-.97h1.27v.97h.13c.78.14 1.13.56 1.13 1.34v2.67h-.13zm4.94-3.24h-1.27v4.55h-1.27v-4.55h-1.27v-1.24h3.81v1.24zm5.27 3.32c0 .58-.35.91-.91.91h-2.37v-1.58h2.05v1.24h-.78c-.28 0-.42-.14-.42-.42v-3.26c0-.28.14-.42.42-.42h.78v1.53h-2.05V9.35h2.37c.56 0 .91.33.91.91v3.32z"/></svg>
          </a>
        </div>
      </div>

      <!-- Lado derecho: Formulario de contacto -->
      <div class="lg:col-span-7 reveal">
        <form class="bg-bg-card border border-border-custom rounded-2xl p-6 md:p-10 flex flex-col gap-5 shadow-lg" id="contactForm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-xs font-semibold text-text-secondary">Nombre completo</label>
              <input type="text" id="name" placeholder="Tu nombre" required class="w-full px-4 py-3 bg-bg-primary border border-border-custom rounded-xl text-white text-sm outline-none transition-all focus:border-accent focus:shadow-[0_0_15px_rgba(0,212,170,0.1)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-xs font-semibold text-text-secondary">Correo electrónico</label>
              <input type="email" id="email" placeholder="tu@email.com" required class="w-full px-4 py-3 bg-bg-primary border border-border-custom rounded-xl text-white text-sm outline-none transition-all focus:border-accent focus:shadow-[0_0_15px_rgba(0,212,170,0.1)]" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-xs font-semibold text-text-secondary">Asunto</label>
            <input type="text" id="subject" placeholder="¿En qué puedo ayudarte?" class="w-full px-4 py-3 bg-bg-primary border border-border-custom rounded-xl text-white text-sm outline-none transition-all focus:border-accent focus:shadow-[0_0_15px_rgba(0,212,170,0.1)]" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-xs font-semibold text-text-secondary">Mensaje</label>
            <textarea id="message" placeholder="Cuéntame sobre tu proyecto o idea..." required rows="4" class="w-full px-4 py-3 bg-bg-primary border border-border-custom rounded-xl text-white text-sm outline-none transition-all focus:border-accent focus:shadow-[0_0_15px_rgba(0,212,170,0.1)] resize-y min-h-[120px]"></textarea>
          </div>

          <button type="submit" class="w-full py-4 px-6 bg-gradient-to-r from-accent to-accent-secondary hover:from-accent hover:to-accent text-bg-primary font-bold rounded-xl transition-all duration-300 transform hover:-translate-y-[2px] shadow-lg hover:shadow-accent-glow flex items-center justify-center gap-2 cursor-pointer">
            Enviar mensaje
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Toast Notification premium -->
  <div class="toast fixed bottom-8 right-8 px-6 py-4 bg-bg-card border border-accent rounded-xl text-accent font-medium text-sm flex items-center gap-2 shadow-2xl transition-all duration-400 translate-y-24 opacity-0 z-50 pointer-events-none" id="toast">
    <span>✅</span> ¡Mensaje enviado correctamente!
  </div>
</section>

<script>
  const contactForm = document.getElementById('contactForm');
  const toast = document.getElementById('toast');

  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Show Toast with smooth slide up
    if (toast) {
      toast.classList.remove('translate-y-24', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
    }

    // Reset Form
    (contactForm as HTMLFormElement).reset();

    // Hide Toast after 3.5 seconds
    setTimeout(() => {
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-24', 'opacity-0');
      }
    }, 3500);
  });
</script>
