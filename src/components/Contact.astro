---
---
<section id="contacto" class="py-24 md:py-32 bg-bg-secondary relative select-none">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16">
      <span class="font-mono text-xs text-accent-secondary uppercase tracking-widest block mb-3">Contacto</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-4">¿Trabajamos juntos?</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-xs sm:text-sm">Estoy siempre abierto a nuevas oportunidades de liderazgo técnico, desarrollo backend y consultoría ágil.</p>
    </div>

    <!-- Contenedor principal de contacto Bento -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-stretch">
      
      <!-- Bento Box Izquierda: Información de contacto -->
      <div class="md:col-span-5 reveal bg-bg-card border border-border-custom rounded-3xl p-6 sm:p-8 shadow-sm hover-glow flex flex-col justify-between gap-6 relative group overflow-hidden">
        <div class="absolute -right-10 -bottom-10 w-28 h-28 bg-accent-secondary/5 rounded-full blur-2xl pointer-events-none group-hover:bg-accent-secondary/10 transition-all duration-500"></div>
        
        <div class="flex flex-col gap-4">
          <h3 class="text-xl font-extrabold text-text-primary leading-snug">
            Hablemos sobre tu <span class="bg-gradient-to-r from-accent-secondary to-[#7c3aed] bg-clip-text text-transparent">próximo proyecto</span>
          </h3>
          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
            Si tienes una idea, un proyecto en mente o simplemente quieres conversar sobre metodologías ágiles o arquitectura técnica, no dudes en escribirme.
          </p>
        </div>

        <!-- Métodos de contacto -->
        <div class="flex flex-col gap-4 border-t border-b border-border-custom py-6 my-2">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-base shrink-0">📧</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Email</span>
              <a href="mailto:delfinncruzricky@gmail.com" class="text-xs font-bold text-text-primary hover:text-accent-secondary transition-colors">delfinncruzricky@gmail.com</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-base shrink-0">📍</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Ubicación</span>
              <p class="text-xs font-bold text-text-primary">Puebla, México (Híbrido / Remoto)</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-base shrink-0">📱</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Teléfono</span>
              <a href="tel:+522214127004" class="text-xs font-bold text-text-primary hover:text-accent-secondary transition-colors">+52 22 1412 7004</a>
            </div>
          </div>
        </div>

        <!-- Redes sociales reales de Ricardo -->
        <div class="flex gap-3 pl-1">
          <a href="https://github.com/NRGxRicky" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent-secondary hover:border-accent-secondary transition-all duration-300 transform hover:-translate-y-0.5 shadow-sm" title="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/ricardo-delfin-n" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-text-secondary hover:text-accent-secondary hover:border-accent-secondary transition-all duration-300 transform hover:-translate-y-0.5 shadow-sm" title="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Bento Box Derecha: Formulario de contacto -->
      <div class="md:col-span-7 reveal">
        <form class="bg-bg-card border border-border-custom rounded-3xl p-6 sm:p-8 md:p-10 flex flex-col gap-5 shadow-sm hover-glow" id="contactForm">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-xs font-semibold text-text-secondary">Nombre completo</label>
              <input type="text" id="name" placeholder="Tu nombre" required class="w-full px-4 py-3 bg-bg-secondary border border-border-custom rounded-xl text-text-primary text-xs sm:text-sm outline-none transition-all focus:border-accent-secondary" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-xs font-semibold text-text-secondary">Correo electrónico</label>
              <input type="email" id="email" placeholder="tu@email.com" required class="w-full px-4 py-3 bg-bg-secondary border border-border-custom rounded-xl text-text-primary text-xs sm:text-sm outline-none transition-all focus:border-accent-secondary" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-xs font-semibold text-text-secondary">Asunto</label>
            <input type="text" id="subject" placeholder="¿En qué puedo ayudarte?" class="w-full px-4 py-3 bg-bg-secondary border border-border-custom rounded-xl text-text-primary text-xs sm:text-sm outline-none transition-all focus:border-accent-secondary" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-xs font-semibold text-text-secondary">Mensaje</label>
            <textarea id="message" placeholder="Cuéntame sobre tu proyecto o idea..." required rows="4" class="w-full px-4 py-3 bg-bg-secondary border border-border-custom rounded-xl text-text-primary text-xs sm:text-sm outline-none transition-all focus:border-accent-secondary resize-y min-h-[100px]"></textarea>
          </div>

          <button type="submit" class="w-full py-3.5 px-6 bg-accent hover:bg-accent-secondary text-white font-bold rounded-full transition-all duration-300 transform hover:-translate-y-[1px] shadow-sm flex items-center justify-center gap-2 cursor-pointer text-xs sm:text-sm">
            Enviar mensaje
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Toast Notification premium -->
  <div class="toast fixed bottom-8 right-8 px-6 py-4 bg-bg-card border border-accent-secondary rounded-xl text-text-primary font-bold text-xs sm:text-sm flex items-center gap-2.5 shadow-xl transition-all duration-400 translate-y-24 opacity-0 z-50 pointer-events-none" id="toast">
    <span class="text-accent-secondary">✓</span> ¡Mensaje enviado correctamente!
  </div>
</section>

<script>
  const contactForm = document.getElementById('contactForm');
  const toast = document.getElementById('toast');

  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Show Toast with smooth slide up
    if (toast) {
      toast.classList.remove('translate-y-24', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
    }

    // Reset Form
    (contactForm as HTMLFormElement).reset();

    // Hide Toast after 3.5 seconds
    setTimeout(() => {
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-24', 'opacity-0');
      }
    }, 3500);
  });
</script>
