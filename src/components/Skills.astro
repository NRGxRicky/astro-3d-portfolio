---
import SkillsRadarChart from './SkillsRadarChart';
---
<section id="habilidades" class="py-24 md:py-32 bg-bg-secondary relative">
  <!-- Sutil resplandor de fondo -->
  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[40vw] h-[40vw] bg-accent-glow/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Habilidades</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">Competencias y Tecnologías</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">El conjunto de metodologías, herramientas y lenguajes con los que gestiono y construyo software robusto.</p>
    </div>

    <!-- Radar Chart Interactivo Centerpiece -->
    <div class="reveal mb-24">
      <SkillsRadarChart client:only="react" />
    </div>

    <!-- Grid de Habilidades Detallado -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Categoría 1: Liderazgo de Proyectos y Liderazgo -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">💼</div>
          <div>
            <h3 class="text-lg font-bold text-white">Liderazgo & Agile</h3>
            <p class="text-xs text-text-muted mt-0.5">Metodologías y gestión ágil</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Metodologías Ágiles</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Scrum</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Kanban</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Gestión de Riesgos</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Seguimiento de KPIs</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">ClickUp</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Jira</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Asana / MS Project</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Metodologías Ágiles (Scrum/Kanban)</span>
              <span class="font-mono text-text-muted">98%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="98%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Gestión de Riesgos & KPIs</span>
              <span class="font-mono text-text-muted">95%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="95%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Categoría 2: Desarrollo Backend & Bases de Datos -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">🔧</div>
          <div>
            <h3 class="text-lg font-bold text-white">Desarrollo Backend & DB</h3>
            <p class="text-xs text-text-muted mt-0.5">Lógica de servidor e integridad de datos</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">APIs RESTful</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">GraphQL</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Java / Java EE</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">PHP / Laravel</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Symfony / Node.js</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">MySQL / PostgreSQL</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">SQL Server</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">MongoDB</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Java / PHP / Laravel</span>
              <span class="font-mono text-text-muted">92%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="92%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">MySQL / PostgreSQL / SQL Server</span>
              <span class="font-mono text-text-muted">90%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="90%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Categoría 3: Frontend & Control de Calidad (QA) -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">⚡</div>
          <div>
            <h3 class="text-lg font-bold text-white">Frontend & QA/Testing</h3>
            <p class="text-xs text-text-muted mt-0.5">Interfaces y control de calidad</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">React Native</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Next.js</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">TypeScript / JS</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">HTML5 / CSS3</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">PHPUnit / Jest</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Testing Unitario</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Integración Continua</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">CI/CD</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">TypeScript / React / Next.js</span>
              <span class="font-mono text-text-muted">88%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="88%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">QA, Testing (PHPUnit/Jest) & CI/CD</span>
              <span class="font-mono text-text-muted">86%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="86%"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Animación progresiva al entrar en pantalla
  const skillBars = document.querySelectorAll('.skill-bar');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target as HTMLElement;
        const targetWidth = bar.getAttribute('data-width') || '0%';
        bar.style.width = targetWidth;
      }
    });
  }, { threshold: 0.2 });

  skillBars.forEach(bar => observer.observe(bar));
</script>
