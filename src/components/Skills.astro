---
---
<section id="habilidades" class="py-24 md:py-32 bg-bg-secondary relative">
  <!-- Sutil resplandor de fondo -->
  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[40vw] h-[40vw] bg-accent-glow/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-20">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Habilidades</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">Tecnologías y herramientas</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Las tecnologías con las que trabajo día a día para crear soluciones de alto impacto.</p>
    </div>

    <!-- Grid de Habilidades -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Categoría 1: Frontend -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">⚡</div>
          <div>
            <h3 class="text-lg font-bold text-white">Frontend</h3>
            <p class="text-xs text-text-muted mt-0.5">Interfaces modernas y responsivas</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">React</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Next.js</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">TypeScript</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Vue.js</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Tailwind CSS</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">HTML5</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">CSS3</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Three.js</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">React / Next.js</span>
              <span class="font-mono text-text-muted">95%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="95%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">TypeScript</span>
              <span class="font-mono text-text-muted">90%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="90%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Categoría 2: Backend -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">🔧</div>
          <div>
            <h3 class="text-lg font-bold text-white">Backend</h3>
            <p class="text-xs text-text-muted mt-0.5">APIs robustas y escalables</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Node.js</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Python</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Go</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Java</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">GraphQL</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">REST APIs</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">PostgreSQL</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">MongoDB</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Node.js / Express</span>
              <span class="font-mono text-text-muted">92%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="92%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Python / FastAPI</span>
              <span class="font-mono text-text-muted">88%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="88%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Categoría 3: Cloud & DevOps -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/30 rounded-2xl p-6 md:p-8 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-glow/5 flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-accent-dim rounded-xl flex items-center justify-center text-2xl text-accent">☁️</div>
          <div>
            <h3 class="text-lg font-bold text-white">Cloud & DevOps</h3>
            <p class="text-xs text-text-muted mt-0.5">Infraestructura y despliegue</p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">AWS</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">GCP</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Docker</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Kubernetes</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Terraform</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">CI/CD</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">GitHub Actions</span>
          <span class="font-mono text-xs px-3 py-1 bg-accent-dim/20 border border-accent/10 rounded-full text-text-secondary hover:text-accent hover:border-accent/40 cursor-default transition-all duration-300">Linux</span>
        </div>

        <!-- Barras de Progreso -->
        <div class="mt-4 flex flex-col gap-4">
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">AWS / GCP</span>
              <span class="font-mono text-text-muted">90%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="90%"></div>
            </div>
          </div>
          <div class="skill-item">
            <div class="flex justify-between items-center text-xs font-semibold mb-1.5">
              <span class="text-white">Docker / K8s</span>
              <span class="font-mono text-text-muted">85%</span>
            </div>
            <div class="w-full h-1.5 bg-bg-primary rounded-full overflow-hidden">
              <div class="skill-bar h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out" data-width="85%"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Animación progresiva al entrar en pantalla
  const skillBars = document.querySelectorAll('.skill-bar');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target as HTMLElement;
        const targetWidth = bar.getAttribute('data-width') || '0%';
        bar.style.width = targetWidth;
      }
    });
  }, { threshold: 0.2 });

  skillBars.forEach(bar => observer.observe(bar));
</script>
