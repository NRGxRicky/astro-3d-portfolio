---
import SkillsRadarChart from './SkillsRadarChart';

// Mapeo de tecnologías con sus respectivas categorías para el filtro interactivo
const techStack = [
  { name: 'Java EE', category: 'backend' },
  { name: 'PHP', category: 'backend' },
  { name: 'Laravel', category: 'backend' },
  { name: 'Symfony', category: 'backend' },
  { name: 'Node.js', category: 'backend' },
  { name: 'Express', category: 'backend' },
  { name: 'Astro', category: 'frontend' },
  { name: 'React', category: 'frontend' },
  { name: 'TypeScript', category: 'frontend' },
  { name: 'SQL Server', category: 'db' },
  { name: 'MySQL', category: 'db' },
  { name: 'PostgreSQL', category: 'db' },
  { name: 'MongoDB', category: 'db' },
  { name: 'GraphQL', category: 'backend' },
  { name: 'REST APIs', category: 'backend' },
  { name: 'Jira', category: 'agile' },
  { name: 'ClickUp', category: 'agile' }
];
---
<section id="habilidades" class="py-24 md:py-32 bg-bg-primary relative select-none">
  <!-- Sutil rejilla interna -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(12,12,15,0.012)_1px,transparent_1px),linear-gradient(90deg,rgba(12,12,15,0.012)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(circle_at_center,black_30%,transparent_80%)] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16">
      <span class="font-mono text-xs text-accent-secondary uppercase tracking-widest block mb-3">Habilidades</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-4">Competencias & Bento Dashboard</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-xs sm:text-sm">Explora mis habilidades técnicas y directivas a través de un panel de control interactivo en tiempo real.</p>
    </div>

    <!-- Panel Bento Grid Principal (Estilo Zypher) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-stretch">
      
      <!-- WIDGET 1: El Radar de Competencias (Ocupa 2 cols x 2 filas en pantallas grandes) -->
      <div class="md:col-span-2 md:row-span-2 reveal bg-bg-card border border-border-custom rounded-3xl p-6 sm:p-8 shadow-sm flex flex-col justify-between gap-6 hover-glow relative overflow-hidden group">
        <div class="absolute -right-10 -bottom-10 w-44 h-44 bg-accent-glow/5 rounded-full blur-[60px] pointer-events-none group-hover:bg-accent-glow/10 transition-all duration-500"></div>
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Centro de control</span>
          <h3 class="text-base sm:text-lg font-extrabold text-text-primary mt-0.5">Radar de Competencias Híbridas</h3>
        </div>
        
        {/* Componente React hidratado */}
        <div class="my-auto py-2">
          <SkillsRadarChart client:only="react" />
        </div>

        <div class="text-[10px] text-text-muted font-semibold border-t border-border-custom pt-4">
          💡 Tip: Interactúa con los nodos para ver detalles específicos extraídos de mi currículum real.
        </div>
      </div>

      {/* WIDGET 2: Sprint Velocity (Agile PM Dashboard con Tooltips Interactivos) */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group relative overflow-hidden">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Productividad Ágil</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">Sprint Velocity (Puntos)</h3>
        </div>

        {/* Gráfico de Barras SVG minimalista con Tooltips */}
        <div class="flex items-end justify-between h-28 px-4">
          
          {/* Barra 1 */}
          <div class="flex flex-col items-center gap-2 w-1/5 relative group/bar">
            {/* Tooltip */}
            <div class="absolute bottom-full mb-2 bg-[#0c0c0f] text-white text-[9px] font-mono font-bold rounded-lg px-2 py-1 shadow-lg opacity-0 pointer-events-none group-hover/bar:opacity-100 group-hover/bar:-translate-y-1 transition-all duration-300 z-30 whitespace-nowrap">
              42 Puntos completados
            </div>
            <div class="w-full bg-bg-secondary border border-border-custom rounded-t-lg h-16 group-hover:bg-bg-secondary/80 transition-all duration-500 relative flex justify-center items-end pb-1.5"><span class="font-mono text-[8px] font-bold text-text-muted">42</span></div>
            <span class="font-mono text-[8px] text-text-muted uppercase font-bold">S24</span>
          </div>

          {/* Barra 2 */}
          <div class="flex flex-col items-center gap-2 w-1/5 relative group/bar">
            {/* Tooltip */}
            <div class="absolute bottom-full mb-2 bg-[#0c0c0f] text-white text-[9px] font-mono font-bold rounded-lg px-2 py-1 shadow-lg opacity-0 pointer-events-none group-hover/bar:opacity-100 group-hover/bar:-translate-y-1 transition-all duration-300 z-30 whitespace-nowrap">
              48 Puntos completados
            </div>
            <div class="w-full bg-bg-secondary border border-border-custom rounded-t-lg h-20 group-hover:bg-bg-secondary/80 transition-all duration-500 relative flex justify-center items-end pb-1.5"><span class="font-mono text-[8px] font-bold text-text-muted">48</span></div>
            <span class="font-mono text-[8px] text-text-muted uppercase font-bold">S25</span>
          </div>

          {/* Barra 3 */}
          <div class="flex flex-col items-center gap-2 w-1/5 relative group/bar">
            {/* Tooltip */}
            <div class="absolute bottom-full mb-2 bg-[#0c0c0f] text-white text-[9px] font-mono font-bold rounded-lg px-2 py-1 shadow-lg opacity-0 pointer-events-none group-hover/bar:opacity-100 group-hover/bar:-translate-y-1 transition-all duration-300 z-30 whitespace-nowrap">
              51 Puntos completados
            </div>
            <div class="w-full bg-bg-secondary border border-border-custom rounded-t-lg h-22 group-hover:bg-bg-secondary/80 transition-all duration-500 relative flex justify-center items-end pb-1.5"><span class="font-mono text-[8px] font-bold text-text-muted">51</span></div>
            <span class="font-mono text-[8px] text-text-muted uppercase font-bold">S26</span>
          </div>

          {/* Barra 4 (Sprint Activo) */}
          <div class="flex flex-col items-center gap-2 w-1/5 relative group/bar">
            {/* Tooltip */}
            <div class="absolute bottom-full mb-2 bg-[#0088ff] text-white text-[9px] font-mono font-bold rounded-lg px-2 py-1 shadow-lg opacity-0 pointer-events-none group-hover/bar:opacity-100 group-hover/bar:-translate-y-1 transition-all duration-300 z-30 whitespace-nowrap">
              55 Puntos (Meta Lograda)
            </div>
            <div class="w-full bg-accent-secondary border border-accent-secondary/10 rounded-t-lg h-24 group-hover:scale-y-[1.03] origin-bottom transition-all duration-500 relative flex justify-center items-end pb-1.5 shadow-sm"><span class="font-mono text-[8px] font-bold text-white">55</span></div>
            <span class="font-mono text-[8px] text-accent-secondary uppercase font-bold">S27</span>
          </div>

        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Compromiso cumplido</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">98.2% (Q1)</span>
        </div>
      </div>

      {/* WIDGET 3: Calidad & Testing (Circular Progress Dial Animado por Scroll) */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group relative overflow-hidden">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Aseguramiento de Calidad</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">Code Coverage (Pruebas)</h3>
        </div>

        {/* Dial Circular en SVG Animado */}
        <div class="flex justify-center items-center h-28 relative">
          <svg class="w-24 h-24 transform -rotate-90">
            <circle cx="48" cy="48" r="38" class="stroke-bg-secondary fill-transparent" stroke-width="6" />
            <circle 
              cx="48" 
              cy="48" 
              r="38" 
              id="qa-circle"
              class="stroke-accent-secondary fill-transparent transition-all duration-1000 ease-out" 
              stroke-width="6" 
              stroke-dasharray="239" 
              stroke-dashoffset="239" 
              stroke-linecap="round"
              data-target-offset="12"
            />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="font-mono text-lg font-extrabold text-text-primary">95%</span>
            <span class="text-[7px] text-text-muted font-bold uppercase tracking-wider">PHPUnit / Jest</span>
          </div>
        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Incremento de calidad</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">+25% QA</span>
        </div>
      </div>

      {/* WIDGET 4: Tablero Kanban Enriquecido (Agile Dashboard Detail) */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Flujo de Trabajo</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">Scrum Kanban Board</h3>
        </div>

        {/* Columnas Kanban Enriquecidas */}
        <div class="grid grid-cols-3 gap-2 my-1">
          {/* TO DO */}
          <div class="flex flex-col gap-1.5">
            <span class="font-mono text-[7px] font-bold text-text-muted uppercase tracking-wider">To Do</span>
            <div class="bg-bg-secondary border border-border-custom rounded-lg p-1.5 flex flex-col gap-1 relative">
              <span class="text-[8px] font-bold text-text-primary leading-snug">Q3 Planning</span>
              <div class="flex items-center justify-between mt-1">
                <span class="text-[6px] font-bold px-1 py-0.2 bg-[#f59e0b]/10 text-[#f59e0b] rounded">Media</span>
                <span class="w-3.5 h-3.5 rounded-full bg-accent text-white text-[6px] font-bold flex items-center justify-center border border-white">RD</span>
              </div>
            </div>
          </div>
          
          {/* DOING */}
          <div class="flex flex-col gap-1.5">
            <span class="font-mono text-[7px] font-bold text-text-muted uppercase tracking-wider">Doing</span>
            <div class="bg-[#0088ff]/5 border border-[#0088ff]/20 rounded-lg p-1.5 flex flex-col gap-1 relative shadow-sm">
              <span class="text-[8px] font-bold text-[#0088ff] leading-snug">API Sync</span>
              {/* Mini barra de progreso */}
              <div class="w-full h-1 bg-bg-secondary rounded-full overflow-hidden mt-0.5">
                <div class="h-full bg-accent-secondary w-[65%]"></div>
              </div>
              <div class="flex items-center justify-between mt-1">
                <span class="text-[6px] font-bold px-1 py-0.2 bg-[#ef4444]/10 text-[#ef4444] rounded">Alta</span>
                <div class="flex -space-x-1">
                  <span class="w-3.5 h-3.5 rounded-full bg-accent text-white text-[6px] font-bold flex items-center justify-center border border-white">RD</span>
                  <span class="w-3.5 h-3.5 rounded-full bg-[#bf5af2] text-white text-[6px] font-bold flex items-center justify-center border border-white">JS</span>
                </div>
              </div>
            </div>
          </div>
          
          {/* DONE */}
          <div class="flex flex-col gap-1.5">
            <span class="font-mono text-[7px] font-bold text-text-muted uppercase tracking-wider">Done</span>
            <div class="bg-bg-secondary/40 border border-border-custom/50 rounded-lg p-1.5 flex flex-col gap-1 opacity-75">
              <span class="text-[7px] font-bold text-text-secondary line-through leading-snug">Jira Setup</span>
              <div class="flex items-center justify-between mt-1">
                <span class="text-[6px] font-bold text-accent-secondary">✓ Listas</span>
                <span class="w-3.5 h-3.5 rounded-full bg-accent text-white text-[6px] font-bold flex items-center justify-center border border-white">RD</span>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Planificación activa</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">Jira / ClickUp</span>
        </div>
      </div>

      {/* WIDGET 5: Stacks Tecnológicos con Sistema de Filtrado Interactivo (Ocupa 2 cols) */}
      <div class="md:col-span-2 reveal bg-bg-card border border-border-custom rounded-3xl p-6 sm:p-8 shadow-sm flex flex-col justify-between gap-5 hover-glow group">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div>
            <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Ingeniería Web</span>
            <h3 class="text-base font-extrabold text-text-primary mt-0.5">Stack de Tecnologías Reales</h3>
          </div>
          
          {/* Botones de Categorías de Filtrado */}
          <div class="flex flex-wrap gap-1.5" id="tech-filters">
            <button data-filter="all" class="tech-filter-btn active px-2.5 py-1 bg-accent text-white border border-accent rounded-full text-[9px] font-mono font-bold cursor-pointer transition-all duration-300">Todos</button>
            <button data-filter="agile" class="tech-filter-btn px-2.5 py-1 bg-bg-secondary text-text-muted hover:text-text-primary border border-border-custom rounded-full text-[9px] font-mono font-bold cursor-pointer transition-all duration-300">Agile / PM</button>
            <button data-filter="backend" class="tech-filter-btn px-2.5 py-1 bg-bg-secondary text-text-muted hover:text-text-primary border border-border-custom rounded-full text-[9px] font-mono font-bold cursor-pointer transition-all duration-300">Backend</button>
            <button data-filter="frontend" class="tech-filter-btn px-2.5 py-1 bg-bg-secondary text-text-muted hover:text-text-primary border border-border-custom rounded-full text-[9px] font-mono font-bold cursor-pointer transition-all duration-300">Frontend</button>
            <button data-filter="db" class="tech-filter-btn px-2.5 py-1 bg-bg-secondary text-text-muted hover:text-text-primary border border-border-custom rounded-full text-[9px] font-mono font-bold cursor-pointer transition-all duration-300">BDs</button>
          </div>
        </div>

        {/* Tags de Tecnologías con categorización para interactividad */}
        <div class="flex flex-wrap gap-2 my-auto" id="tech-tags-container">
          {techStack.map((tech) => (
            <span 
              data-category={tech.category}
              class="tech-tag font-mono text-[10px] font-bold px-3 py-1.5 bg-bg-secondary border border-border-custom rounded-full text-text-secondary hover:text-accent-secondary hover:border-accent-secondary/40 cursor-default transition-all duration-300 transform hover:scale-[1.03]"
            >
              {tech.name}
            </span>
          ))}
        </div>

        <div class="border-t border-border-custom pt-3 text-[10px] text-text-secondary font-semibold" id="tech-description">
          Despliegues continuos utilizando integraciones robustas y bases de datos seguras.
        </div>
      </div>

      {/* WIDGET 6: Mitigación de Riesgos y Control de Calidad */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Gestión de Riesgos</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">Mitigación Técnica</h3>
        </div>

        {/* Métricas e Indicador */}
        <div class="flex flex-col gap-2 my-1">
          <div class="flex justify-between items-baseline">
            <span class="font-mono text-3xl font-extrabold text-accent-secondary">-30%</span>
            <span class="text-[9px] text-text-secondary font-bold uppercase tracking-wider">Incidentes de Dependencia</span>
          </div>
          <div class="w-full h-2 bg-bg-secondary border border-border-custom rounded-full overflow-hidden">
            <div class="h-full bg-accent-secondary rounded-full w-0 transition-all duration-1000 ease-out risk-bar" data-width="70%"></div>
          </div>
          <p class="text-[10px] text-text-secondary leading-relaxed mt-1">
            Reducción proactiva de acoplamiento de sistemas de negocio y APIs críticas.
          </p>
        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Tasa de éxito</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">100% On-Time</span>
        </div>
      </div>

      {/* WIDGET 7: Certificaciones Oficiales */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Crendenciales Internacionales</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">Certificaciones Agile & PM</h3>
        </div>

        {/* Listado de Certificaciones con Insignias */}
        <div class="flex flex-col gap-2.5 my-1">
          <div class="flex items-center gap-3">
            <span class="text-lg">🥇</span>
            <div>
              <h4 class="text-xs font-extrabold text-text-primary">PMP® (Project Management Professional)</h4>
              <p class="text-[9px] text-text-muted uppercase font-bold">PMI • Lic. 3192323</p>
            </div>
          </div>
          <div class="flex items-center gap-3 border-t border-border-custom pt-2">
            <span class="text-lg">🥈</span>
            <div>
              <h4 class="text-xs font-extrabold text-text-primary">CSM® (Certified Scrum Master)</h4>
              <p class="text-[9px] text-text-muted uppercase font-bold">Scrum Alliance • Scrum Master</p>
            </div>
          </div>
        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Total certificaciones</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">8 Certificaciones</span>
        </div>
      </div>

      {/* WIDGET 8: Integraciones Hub & APIs */}
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-4 hover-glow group">
        <div>
          <span class="font-mono text-[9px] font-bold text-accent-secondary uppercase tracking-wider">Sistemas de Información</span>
          <h3 class="text-base font-extrabold text-text-primary mt-0.5">API Hub Integrations</h3>
        </div>

        {/* Checkbox List */}
        <div class="flex flex-col gap-2 my-1">
          <div class="flex items-center justify-between text-xs text-text-secondary">
            <span class="font-medium flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-accent-secondary animate-pulse"></span>
              Contactus CRM API
            </span>
            <span class="font-mono text-[9px] font-bold text-accent-secondary">✓ Activa</span>
          </div>
          <div class="flex items-center justify-between text-xs text-text-secondary border-t border-border-custom pt-2">
            <span class="font-medium flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-accent-secondary animate-pulse"></span>
              ERP RIPIPSA Gateway
            </span>
            <span class="font-mono text-[9px] font-bold text-accent-secondary">✓ Activa</span>
          </div>
          <div class="flex items-center justify-between text-xs text-text-secondary border-t border-border-custom pt-2">
            <span class="font-medium flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-accent-secondary animate-pulse"></span>
              Hera Apparel Logistics
            </span>
            <span class="font-mono text-[9px] font-bold text-accent-secondary">✓ Activa</span>
          </div>
        </div>

        <div class="border-t border-border-custom pt-3 flex items-center justify-between">
          <span class="text-[10px] text-text-secondary font-semibold">Sistemas Integrados</span>
          <span class="font-mono text-xs font-extrabold text-accent-secondary">REST / OAuth</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // 1. Animación progresiva al entrar en pantalla (Barras e Indicador Circular QA)
  const riskBars = document.querySelectorAll('.risk-bar');
  const qaCircle = document.getElementById('qa-circle');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        if (entry.target.classList.contains('risk-bar')) {
          const bar = entry.target as HTMLElement;
          const targetWidth = bar.getAttribute('data-width') || '0%';
          bar.style.width = targetWidth;
          observer.unobserve(bar);
        } else if (entry.target.id === 'qa-circle') {
          const circle = entry.target as HTMLElement;
          const targetOffset = circle.getAttribute('data-target-offset') || '0';
          circle.style.strokeDashoffset = targetOffset;
          observer.unobserve(circle);
        }
      }
    });
  }, { threshold: 0.1 });

  riskBars.forEach(bar => observer.observe(bar));
  if (qaCircle) observer.observe(qaCircle);

  // 2. Sistema de Filtrado de Tecnologías Interactivo
  const filterBtns = document.querySelectorAll('.tech-filter-btn');
  const techTags = document.querySelectorAll('.tech-tag');
  const techDesc = document.getElementById('tech-description');

  const filterDescriptions: Record<string, string> = {
    all: 'Despliegues continuos utilizando integraciones robustas y bases de datos seguras.',
    agile: 'Gestión de equipos, mitigación de riesgos y planificación iterativa en ClickUp y Jira.',
    backend: 'Arquitectura de servidores, APIs RESTful y GraphQL construidas de manera segura en Java, PHP y Node.js.',
    frontend: 'Desarrollo de interfaces del lado del cliente altamente interactivas con React, Next.js y Astro.',
    db: 'Optimización de consultas complejas y mantenimiento de bases de datos robustas (SQL & NoSQL).'
  };

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remover clase activa de todos los botones
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-accent', 'text-white', 'border-accent');
        b.classList.add('bg-bg-secondary', 'text-text-muted', 'border-border-custom');
      });

      // Agregar clase activa al botón presionado
      btn.classList.add('active', 'bg-accent', 'text-white', 'border-accent');
      btn.classList.remove('bg-bg-secondary', 'text-text-muted', 'border-border-custom');

      const filter = btn.getAttribute('data-filter') || 'all';

      // Actualizar descripción del stack interactivo
      if (techDesc && filterDescriptions[filter]) {
        techDesc.textContent = filterDescriptions[filter];
      }

      // Filtrar los tags
      techTags.forEach(tag => {
        const tagCategory = tag.getAttribute('data-category');
        const htmlTag = tag as HTMLElement;

        if (filter === 'all' || tagCategory === filter) {
          htmlTag.style.opacity = '1';
          htmlTag.style.transform = 'scale(1)';
          htmlTag.classList.add('border-accent-secondary/30', 'text-accent-secondary', 'bg-[#0088ff]/5');
          htmlTag.classList.remove('text-text-secondary', 'bg-bg-secondary');
        } else {
          htmlTag.style.opacity = '0.25';
          htmlTag.style.transform = 'scale(0.95)';
          htmlTag.classList.remove('border-accent-secondary/30', 'text-accent-secondary', 'bg-[#0088ff]/5');
          htmlTag.classList.add('text-text-secondary', 'bg-bg-secondary');
        }
      });
    });
  });

  // Gatillar el filtro "Todos" por defecto al cargar para establecer estilos iniciales
  const defaultBtn = document.querySelector('.tech-filter-btn[data-filter="all"]');
  if (defaultBtn) (defaultBtn as HTMLElement).click();
</script>
