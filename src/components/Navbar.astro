---
---
<nav id="navbar" class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[92%] max-w-7xl py-3 px-6 md:px-8 bg-[#0c0c0f]/95 border border-white/10 rounded-full text-white shadow-[0_12px_35px_rgba(0,0,0,0.18)] transition-all duration-400 ease-in-out flex justify-between items-center select-none">
  <!-- Logo -->
  <a href="#inicio" class="font-mono text-base sm:text-lg font-bold text-white tracking-wider hover:opacity-85 transition-opacity">
    &lt;RD<span class="text-white/40 font-normal">/&gt;</span>
  </a>

  <!-- Desktop Navigation Links -->
  <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
    <li><a href="#sobre-mi" class="text-xs font-semibold text-white/70 hover:text-white transition-colors duration-300">Sobre mí</a></li>
    <li><a href="#formacion" class="text-xs font-semibold text-white/70 hover:text-white transition-colors duration-300">Formación</a></li>
    <li><a href="#habilidades" class="text-xs font-semibold text-white/70 hover:text-white transition-colors duration-300">Habilidades</a></li>
    <li><a href="#proyectos" class="text-xs font-semibold text-white/70 hover:text-white transition-colors duration-300">Proyectos</a></li>
    <li><a href="#experiencia" class="text-xs font-semibold text-white/70 hover:text-white transition-colors duration-300">Experiencia</a></li>
  </ul>

  <!-- Desktop Button -->
  <div class="hidden md:block">
    <a href="#contacto" class="text-xs font-bold px-5 py-2.5 bg-white text-black hover:bg-white/90 rounded-full shadow-md transition-all duration-300">
      Get in Touch
    </a>
  </div>

  <!-- Hamburger Menu Toggle Button -->
  <button id="hamburger" aria-label="Toggle Menu" class="md:hidden flex flex-col justify-center items-center gap-[4px] w-8 h-8 cursor-pointer focus:outline-none z-50 text-white">
    <span class="w-5 h-[2px] bg-white rounded-full transition-transform duration-300 ease-in-out origin-center"></span>
    <span class="w-5 h-[2px] bg-white rounded-full transition-opacity duration-300 ease-in-out"></span>
    <span class="w-5 h-[2px] bg-white rounded-full transition-transform duration-300 ease-in-out origin-center"></span>
  </button>

  <!-- Mobile Drawer Menu (Black floating pill drawer) -->
  <div id="mobileMenu" class="md:hidden fixed top-20 left-1/2 -translate-x-1/2 w-[92%] max-w-sm bg-[#0c0c0f]/98 border border-white/10 rounded-3xl flex flex-col py-6 px-8 gap-4 transition-all duration-300 ease-in-out z-40 shadow-2xl opacity-0 pointer-events-none scale-95 origin-top">
    <a href="#sobre-mi" class="mobile-link text-sm font-semibold text-white/70 hover:text-white py-1">Sobre mí</a>
    <a href="#formacion" class="mobile-link text-sm font-semibold text-white/70 hover:text-white py-1">Formación</a>
    <a href="#habilidades" class="mobile-link text-sm font-semibold text-white/70 hover:text-white py-1">Habilidades</a>
    <a href="#proyectos" class="mobile-link text-sm font-semibold text-white/70 hover:text-white py-1">Proyectos</a>
    <a href="#experiencia" class="mobile-link text-sm font-semibold text-white/70 hover:text-white py-1">Experiencia</a>
    <a href="#contacto" class="mobile-link text-sm font-bold bg-white text-black text-center py-2.5 rounded-full mt-2">Get in Touch</a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  // Navbar scroll effect with high-end docking feel
  window.addEventListener('scroll', () => {
    if (window.scrollY > 30) {
      navbar?.classList.add('py-2', 'bg-[#0c0c0f]', 'shadow-[0_12px_45px_rgba(0,0,0,0.22)]', 'top-3', 'max-w-6xl');
      navbar?.classList.remove('py-3', 'bg-[#0c0c0f]/95', 'top-6', 'max-w-7xl');
    } else {
      navbar?.classList.remove('py-2', 'bg-[#0c0c0f]', 'shadow-[0_12px_45px_rgba(0,0,0,0.22)]', 'top-3', 'max-w-6xl');
      navbar?.classList.add('py-3', 'bg-[#0c0c0f]/95', 'top-6', 'max-w-7xl');
    }
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isActive = mobileMenu?.classList.contains('opacity-100');
    const spans = hamburger.querySelectorAll('span');
    
    if (!isActive) {
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
      mobileMenu?.classList.add('opacity-100', 'pointer-events-auto', 'scale-100');
      
      spans[0].style.transform = 'rotate(45deg) translate(4px, 4px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(4px, -4px)';
    } else {
      closeMenu();
    }
  });

  function closeMenu() {
    mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100');
    mobileMenu?.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
    
    const spans = hamburger?.querySelectorAll('span');
    if (spans) {
      spans[0].style.transform = 'none';
      spans[1].style.opacity = '1';
      spans[2].style.transform = 'none';
    }
  }

  // Close menu when clicking links
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
