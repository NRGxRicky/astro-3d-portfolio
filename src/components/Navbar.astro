---
---
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 py-5 transition-all duration-400 ease-in-out border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center">
    <!-- Logo -->
    <a href="#inicio" class="font-mono text-xl font-bold text-accent tracking-wider hover:opacity-90 transition-opacity">
      &lt;RD<span class="text-text-muted font-normal">/&gt;</span>
    </a>

    <!-- Desktop Navigation Links -->
    <ul class="hidden md:flex items-center gap-10 list-none">
      <li><a href="#sobre-mi" class="text-sm font-medium text-text-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-accent hover:after:w-full after:transition-all after:duration-300">Sobre mí</a></li>
      <li><a href="#formacion" class="text-sm font-medium text-text-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-accent hover:after:w-full after:transition-all after:duration-300">Formación</a></li>
      <li><a href="#habilidades" class="text-sm font-medium text-text-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-accent hover:after:w-full after:transition-all after:duration-300">Habilidades</a></li>
      <li><a href="#proyectos" class="text-sm font-medium text-text-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-accent hover:after:w-full after:transition-all after:duration-300">Proyectos</a></li>
      <li><a href="#experiencia" class="text-sm font-medium text-text-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-accent hover:after:w-full after:transition-all after:duration-300">Experiencia</a></li>
      <li>
        <a href="#contacto" class="text-sm font-medium px-5 py-2 border border-accent rounded-lg text-accent bg-accent-dim/30 hover:bg-accent hover:text-bg-primary transition-all duration-300 shadow-sm hover:shadow-accent-glow">
          Contacto
        </a>
      </li>
    </ul>

    <!-- Hamburger Menu Toggle Button -->
    <button id="hamburger" aria-label="Toggle Menu" class="md:hidden flex flex-col justify-center items-center gap-[5px] w-8 h-8 cursor-pointer focus:outline-none z-50">
      <span class="w-6 h-[2px] bg-text-primary rounded-full transition-transform duration-300 ease-in-out origin-center"></span>
      <span class="w-6 h-[2px] bg-text-primary rounded-full transition-opacity duration-300 ease-in-out"></span>
      <span class="w-6 h-[2px] bg-text-primary rounded-full transition-transform duration-300 ease-in-out origin-center"></span>
    </button>
  </div>

  <!-- Mobile Drawer Menu -->
  <div id="mobileMenu" class="md:hidden fixed top-0 right-[-100%] w-72 h-screen bg-bg-secondary/95 backdrop-blur-xl border-l border-border-custom flex flex-col pt-24 px-8 gap-6 transition-all duration-300 ease-in-out z-40 shadow-2xl">
    <a href="#sobre-mi" class="mobile-link text-lg font-medium text-text-secondary hover:text-accent transition-colors">Sobre mí</a>
    <a href="#formacion" class="mobile-link text-lg font-medium text-text-secondary hover:text-accent transition-colors">Formación</a>
    <a href="#habilidades" class="mobile-link text-lg font-medium text-text-secondary hover:text-accent transition-colors">Habilidades</a>
    <a href="#proyectos" class="mobile-link text-lg font-medium text-text-secondary hover:text-accent transition-colors">Proyectos</a>
    <a href="#experiencia" class="mobile-link text-lg font-medium text-text-secondary hover:text-accent transition-colors">Experiencia</a>
    <a href="#contacto" class="mobile-link text-lg font-medium text-accent border border-accent/30 rounded-lg py-3 text-center bg-accent-dim/10 hover:bg-accent hover:text-bg-primary transition-all">Contacto</a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar?.classList.add('bg-bg-primary/80', 'backdrop-blur-xl', 'border-border-custom', 'py-4');
      navbar?.classList.remove('py-5', 'border-transparent');
    } else {
      navbar?.classList.remove('bg-bg-primary/80', 'backdrop-blur-xl', 'border-border-custom', 'py-4');
      navbar?.classList.add('py-5', 'border-transparent');
    }
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isActive = mobileMenu?.classList.contains('right-0');
    
    // Animate hamburger icons
    const spans = hamburger.querySelectorAll('span');
    if (!isActive) {
      mobileMenu?.classList.remove('right-[-100%]');
      mobileMenu?.classList.add('right-0');
      
      spans[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(5px, -5px)';
    } else {
      closeMenu();
    }
  });

  function closeMenu() {
    mobileMenu?.classList.remove('right-0');
    mobileMenu?.classList.add('right-[-100%]');
    
    const spans = hamburger?.querySelectorAll('span');
    if (spans) {
      spans[0].style.transform = 'none';
      spans[1].style.opacity = '1';
      spans[2].style.transform = 'none';
    }
  }

  // Close menu when clicking links
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
