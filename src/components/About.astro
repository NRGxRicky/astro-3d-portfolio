---
---
<section id="sobre-mi" class="py-24 md:py-32 bg-bg-secondary relative select-none">
  <div class="max-w-5xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16">
      <span class="font-mono text-xs text-accent-secondary uppercase tracking-widest block mb-3">Sobre mí</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-4">Conoce mi trayectoria</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Facilitando la sinergia entre la ingeniería técnica y los objetivos de negocio.</p>
    </div>

    <!-- Grid principal Bento (Estilo Zypher) -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-stretch">
      
      <!-- Bento Box Izquierda: Foto y Hitos Principales -->
      <div class="md:col-span-5 reveal bg-bg-card border border-border-custom rounded-3xl p-6 shadow-sm flex flex-col justify-between gap-6 relative overflow-hidden group">
        <!-- Brillo decorativo -->
        <div class="absolute -right-10 -top-10 w-28 h-28 bg-accent-secondary/5 rounded-full blur-2xl pointer-events-none group-hover:bg-accent-secondary/10 transition-all duration-500"></div>

        <!-- Foto de Perfil -->
        <div class="w-full aspect-[4/5] rounded-2xl overflow-hidden border border-border-custom shadow-sm bg-bg-primary">
          <img src="/assets/profile.png" alt="Ricardo Delfín - Technical Project Manager" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>

        {/* Pequeña tarjeta interna del Bento */}
        <div class="bg-bg-primary/50 border border-border-custom rounded-2xl p-4 flex items-center gap-4">
          <div class="w-10 h-10 bg-white border border-border-custom rounded-full flex items-center justify-center text-lg shadow-sm shrink-0">
            🚀
          </div>
          <div>
            <h4 class="text-xs font-bold text-text-primary">+7 años de experiencia</h4>
            <p class="text-[10px] text-text-secondary mt-0.5">Liderazgo de proyectos y desarrollo</p>
          </div>
        </div>
      </div>

      <!-- Bento Box Derecha: Biografía y Métricas Clave -->
      <div class="md:col-span-7 reveal bg-bg-card border border-border-custom rounded-3xl p-6 sm:p-8 md:p-10 shadow-sm flex flex-col justify-between gap-6">
        <div class="flex flex-col gap-4">
          <h3 class="text-xl sm:text-2xl md:text-3xl font-extrabold text-text-primary leading-snug">
            Technical Project Manager <span class="text-accent-secondary">&</span> Software Engineer
          </h3>
          
          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
            Soy un Technical Project Manager con más de 7 años de experiencia liderando equipos multidisciplinarios y coordinando proyectos de software de alto impacto. Mi enfoque fusiona una sólida base técnica en desarrollo de software con habilidades analíticas y de liderazgo ágil.
          </p>

          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
            Me especializo en implementar metodologías ágiles como Scrum y Kanban, mitigando riesgos técnicos y de negocio, gestionando presupuestos y alineando las prioridades de desarrollo técnico con los objetivos de producto y stakeholders clave.
          </p>
        </div>

        <!-- Cuadrícula de Datos de Perfil (Bento Widgets) -->
        <div class="grid grid-cols-2 gap-4 border-t border-border-custom pt-6">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-sm shrink-0">📍</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Ubicación</span>
              <p class="text-xs font-bold text-text-primary">Puebla, México (Híbrido)</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-sm shrink-0">🎓</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Formación</span>
              <p class="text-xs font-bold text-text-primary">Ingeniería TIC / PMP</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-sm shrink-0">💼</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Experiencia</span>
              <p class="text-xs font-bold text-text-primary">+7 Años Profesionales</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-bg-secondary border border-border-custom rounded-xl flex items-center justify-center text-sm shrink-0">🌐</div>
            <div>
              <span class="block text-[8px] text-text-muted uppercase tracking-wider font-semibold">Certs</span>
              <p class="text-xs font-bold text-text-primary">PMP, CSM, PMI-ACP</p>
            </div>
          </div>
        </div>

        <!-- Botones de Acción -->
        <div class="flex flex-wrap gap-3 border-t border-border-custom pt-6">
          <a href="#contacto" class="inline-flex items-center gap-2 px-6 py-2.5 bg-accent hover:bg-accent-secondary hover:text-white text-white font-bold rounded-full transition-all duration-300 transform hover:-translate-y-[1px] shadow-sm text-xs">
            Hablemos
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/assets/CV_Ricardo_Delfin.pdf" download class="inline-flex items-center gap-2 px-6 py-2.5 border border-border-custom hover:border-accent hover:text-accent font-semibold rounded-full bg-accent-dim transition-all duration-300 transform hover:-translate-y-[1px] text-xs">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="animate-bounce"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar CV
          </a>
        </div>

      </div>

    </div>
  </div>
</section>
