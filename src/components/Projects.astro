---
---
<section id="proyectos" class="py-24 md:py-32 bg-bg-primary relative select-none">
  <!-- Sutil rejilla de fondo -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(12,12,15,0.012)_1px,transparent_1px),linear-gradient(90deg,rgba(12,12,15,0.012)_1px,transparent_1px)] bg-[size:45px_45px] [mask-image:radial-gradient(circle_at_center,black_30%,transparent_80%)] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16">
      <span class="font-mono text-xs text-accent-secondary uppercase tracking-widest block mb-3">Proyectos</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-4">Trabajo Destacado</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-xs sm:text-sm">Una selección de mis proyectos de software y arquitecturas de sistemas más relevantes.</p>
    </div>

    <!-- Grid de proyectos Bento -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Proyecto 1: CloudSync Dashboard -->
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl overflow-hidden shadow-sm hover-glow transition-all duration-500 transform hover:-translate-y-1.5 group flex flex-col justify-between">
        <div>
          <!-- Contenedor de Imagen y Overlay -->
          <div class="relative h-48 w-full overflow-hidden bg-bg-secondary border-b border-border-custom">
            <img src="/assets/project-1.png" alt="CloudSync Dashboard" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <!-- Overlay interactivo -->
            <div class="absolute inset-0 bg-[#0c0c0f]/80 flex items-center justify-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white text-black hover:bg-white/90 font-bold text-xs rounded-full transition-all">
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-bold text-xs rounded-full transition-all">
                Código
              </a>
            </div>
          </div>

          <!-- Contenido principal -->
          <div class="p-6 flex flex-col gap-3.5">
            <!-- Tags de tecnologías -->
            <div class="flex flex-wrap gap-1.5">
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">React</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">Node.js</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">AWS</span>
            </div>

            <h3 class="text-base sm:text-lg font-extrabold text-text-primary group-hover:text-accent-secondary transition-colors duration-300">CloudSync Dashboard</h3>
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
              Plataforma de monitoreo en tiempo real para infraestructura cloud multi-proveedor con dashboards interactivos y alertas inteligentes.
            </p>
          </div>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/30">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#0088ff" stroke="#0088ff"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-bold text-[10px] text-text-secondary">248 stars</span>
          </div>
          <a href="#" class="text-xs font-bold text-accent-secondary flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Proyecto 2: AI Code Reviewer -->
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl overflow-hidden shadow-sm hover-glow transition-all duration-500 transform hover:-translate-y-1.5 group flex flex-col justify-between">
        <div>
          <!-- Contenedor de Imagen y Overlay -->
          <div class="relative h-48 w-full overflow-hidden bg-bg-secondary border-b border-border-custom">
            <img src="/assets/project-2.png" alt="AI Code Reviewer" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <!-- Overlay interactivo -->
            <div class="absolute inset-0 bg-[#0c0c0f]/80 flex items-center justify-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white text-black hover:bg-white/90 font-bold text-xs rounded-full transition-all">
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-bold text-xs rounded-full transition-all">
                Código
              </a>
            </div>
          </div>

          <!-- Contenido principal -->
          <div class="p-6 flex flex-col gap-3.5">
            <!-- Tags de tecnologías -->
            <div class="flex flex-wrap gap-1.5">
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">Python</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">FastAPI</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">TensorFlow</span>
            </div>

            <h3 class="text-base sm:text-lg font-extrabold text-text-primary group-hover:text-accent-secondary transition-colors duration-300">AI Code Reviewer</h3>
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
              Sistema de revisión automática de código basado en IA que detecta bugs, vulnerabilidades de seguridad y sugiere mejoras de rendimiento.
            </p>
          </div>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/30">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#0088ff" stroke="#0088ff"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-bold text-[10px] text-text-secondary">186 stars</span>
          </div>
          <a href="#" class="text-xs font-bold text-accent-secondary flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Proyecto 3: FinTrack App -->
      <div class="reveal bg-bg-card border border-border-custom rounded-3xl overflow-hidden shadow-sm hover-glow transition-all duration-500 transform hover:-translate-y-1.5 group flex flex-col justify-between">
        <div>
          <!-- Contenedor de Imagen y Overlay -->
          <div class="relative h-48 w-full overflow-hidden bg-bg-secondary border-b border-border-custom">
            <img src="/assets/project-3.png" alt="FinTrack App" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <!-- Overlay interactivo -->
            <div class="absolute inset-0 bg-[#0c0c0f]/80 flex items-center justify-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white text-black hover:bg-white/90 font-bold text-xs rounded-full transition-all">
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-bold text-xs rounded-full transition-all">
                Código
              </a>
            </div>
          </div>

          <!-- Contenido principal -->
          <div class="p-6 flex flex-col gap-3.5">
            <!-- Tags de tecnologías -->
            <div class="flex flex-wrap gap-1.5">
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">Next.js</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">TypeScript</span>
              <span class="font-mono text-[9px] font-bold text-accent-secondary px-2.5 py-1 bg-bg-secondary rounded-full border border-border-custom">Postgres</span>
            </div>

            <h3 class="text-base sm:text-lg font-extrabold text-text-primary group-hover:text-accent-secondary transition-colors duration-300">FinTrack App</h3>
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">
              Aplicación SaaS de gestión financiera personal con análisis de gastos, presupuestos inteligentes y reportes automatizados.
            </p>
          </div>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/30">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#0088ff" stroke="#0088ff"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-bold text-[10px] text-text-secondary">312 stars</span>
          </div>
          <a href="#" class="text-xs font-bold text-accent-secondary flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
