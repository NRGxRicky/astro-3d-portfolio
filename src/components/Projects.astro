---
---
<section id="proyectos" class="py-24 md:py-32 bg-bg-primary relative">
  <!-- Sutil brillo de fondo -->
  <div class="absolute right-0 top-1/3 w-[35vw] h-[35vw] bg-accent-glow/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header de sección -->
    <div class="reveal text-center mb-16 md:mb-20">
      <span class="font-mono text-xs text-accent uppercase tracking-widest block mb-3">Proyectos</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4">Trabajo destacado</h2>
      <p class="text-text-secondary max-w-xl mx-auto text-base md:text-lg">Una selección de mis proyectos más relevantes e innovadores.</p>
    </div>

    <!-- Grid de proyectos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Proyecto 1: CloudSync Dashboard -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl overflow-hidden shadow-md hover:shadow-2xl hover:shadow-accent-glow/5 transition-all duration-500 transform hover:-translate-y-2 group">
        <!-- Contenedor de Imagen y Overlay -->
        <div class="relative h-56 w-full overflow-hidden bg-bg-primary">
          <img src="/assets/project-1.png" alt="CloudSync Dashboard" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <!-- Overlay interactivo -->
          <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/95 via-bg-primary/40 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="flex gap-3">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Código
              </a>
            </div>
          </div>
        </div>

        <!-- Contenido principal -->
        <div class="p-6 flex flex-col gap-4">
          <!-- Tags de tecnologías -->
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">React</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">Node.js</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">AWS</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">GraphQL</span>
          </div>

          <h3 class="text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">CloudSync Dashboard</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Plataforma de monitoreo en tiempo real para infraestructura cloud multi-proveedor con dashboards interactivos y alertas inteligentes.
          </p>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/40">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-semibold text-text-secondary">248</span>
          </div>
          <a href="#" class="text-xs font-semibold text-accent flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Proyecto 2: AI Code Reviewer -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl overflow-hidden shadow-md hover:shadow-2xl hover:shadow-accent-glow/5 transition-all duration-500 transform hover:-translate-y-2 group">
        <!-- Contenedor de Imagen y Overlay -->
        <div class="relative h-56 w-full overflow-hidden bg-bg-primary">
          <img src="/assets/project-2.png" alt="AI Code Reviewer" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <!-- Overlay interactivo -->
          <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/95 via-bg-primary/40 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="flex gap-3">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Código
              </a>
            </div>
          </div>
        </div>

        <!-- Contenido principal -->
        <div class="p-6 flex flex-col gap-4">
          <!-- Tags de tecnologías -->
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">Python</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">FastAPI</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">TensorFlow</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">Docker</span>
          </div>

          <h3 class="text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">AI Code Reviewer</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Sistema de revisión automática de código basado en IA que detecta bugs, vulnerabilidades de seguridad y sugiere mejoras de rendimiento.
          </p>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/40">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-semibold text-text-secondary">186</span>
          </div>
          <a href="#" class="text-xs font-semibold text-accent flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Proyecto 3: FinTrack App -->
      <div class="reveal bg-bg-card border border-border-custom hover:border-accent/40 rounded-2xl overflow-hidden shadow-md hover:shadow-2xl hover:shadow-accent-glow/5 transition-all duration-500 transform hover:-translate-y-2 group">
        <!-- Contenedor de Imagen y Overlay -->
        <div class="relative h-56 w-full overflow-hidden bg-bg-primary">
          <img src="/assets/project-3.png" alt="FinTrack App" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <!-- Overlay interactivo -->
          <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/95 via-bg-primary/40 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="flex gap-3">
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Demo
              </a>
              <a href="#" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/10 hover:bg-accent hover:text-bg-primary backdrop-blur-md text-white font-medium text-xs rounded-lg transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Código
              </a>
            </div>
          </div>
        </div>

        <!-- Contenido principal -->
        <div class="p-6 flex flex-col gap-4">
          <!-- Tags de tecnologías -->
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">Next.js</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">TypeScript</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">PostgreSQL</span>
            <span class="font-mono text-[10px] text-accent px-2 py-0.5 bg-accent-dim/30 rounded border border-accent/10">Stripe</span>
          </div>

          <h3 class="text-xl font-bold text-white group-hover:text-accent transition-colors duration-300">FinTrack App</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Aplicación SaaS de gestión financiera personal con análisis de gastos, presupuestos inteligentes y reportes automatizados.
          </p>
        </div>

        <!-- Footer de la tarjeta -->
        <div class="px-6 py-4 border-t border-border-custom flex justify-between items-center bg-bg-secondary/40">
          <div class="flex items-center gap-1.5 text-xs text-text-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="font-semibold text-text-secondary">312</span>
          </div>
          <a href="#" class="text-xs font-semibold text-accent flex items-center gap-1 hover:gap-2 transition-all">
            Ver más
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
